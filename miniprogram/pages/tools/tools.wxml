<!--pages/tools/tools.wxml-->
<view class="container">
  <!-- 用户统计概览 -->
  <view class="stats-card">
    <view class="stats-header">我的游戏库</view>
    <view class="stats-content">
      <view class="stat-item">
        <text class="stat-value">{{userStats.totalGames}}</text>
        <text class="stat-label">总游戏数</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{userStats.playedGames}}</text>
        <text class="stat-label">已通关</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{userStats.avgRating}}</text>
        <text class="stat-label">平均分</text>
      </view>
    </view>
  </view>

  <!-- 工具列表 -->
  <view class="tools-section">
    <view class="section-header">
      <text class="section-title">工具</text>
      <text class="section-action" bindtap="onCreateList">创建清单</text>
    </view>
    
    <view class="tools-grid">
      <view class="tool-card" 
            wx:for="{{tools}}" 
            wx:key="id"
            data-url="{{item.url}}"
            bindtap="onToolTap">
        <view class="tool-icon">{{item.icon}}</view>
        <view class="tool-content">
          <text class="tool-title">{{item.title}}</text>
          <text class="tool-desc">{{item.desc}}</text>
        </view>
        <view class="tool-arrow">›</view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>













































