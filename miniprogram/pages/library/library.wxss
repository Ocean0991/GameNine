/* pages/library/library.wxss */
.library-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

/* 状态标签栏 */
.tab-bar {
  display: flex;
  background-color: #1a1a2e;
  padding: 20rpx 0;
  position: sticky;
  top: 0;
  z-index: 100;
}

.tab-item {
  flex: 1;
  text-align: center;
  color: #999999;
  font-size: 28rpx;
  padding: 16rpx 0;
  position: relative;
}

.tab-item.active {
  color: #ffffff;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #4a9eff;
  border-radius: 2rpx;
}

/* 游戏列表 */
.game-list {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  color: #999999;
  font-size: 28rpx;
  margin-bottom: 40rpx;
}

.add-btn {
  background-color: #4a9eff;
  color: #ffffff;
  border: none;
  border-radius: 40rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
}

/* 游戏卡片 */
.game-item {
  display: flex;
  background-color: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.game-cover {
  width: 160rpx;
  height: 220rpx;
  flex-shrink: 0;
}

.game-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.game-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.game-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.rating {
  display: flex;
  align-items: center;
  color: #ff9500;
}

.star {
  font-size: 28rpx;
  margin-right: 4rpx;
}

.score {
  font-size: 26rpx;
  font-weight: bold;
}

.date {
  color: #999999;
  font-size: 24rpx;
}

.comment {
  color: #666666;
  font-size: 26rpx;
  margin-top: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  line-height: 1.5;
}

/* 加载状态 */
.loading, .no-more {
  text-align: center;
  padding: 30rpx 0;
  color: #999999;
  font-size: 26rpx;
}

/* 悬浮添加按钮 */
.fab-button {
  position: fixed;
  right: 40rpx;
  bottom: 100rpx;
  width: 100rpx;
  height: 100rpx;
  background-color: #4a9eff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(74, 158, 255, 0.4);
}

.fab-icon {
  color: #ffffff;
  font-size: 60rpx;
  font-weight: 300;
}































































































































































