/* pages/discover/discover.wxss */
.container {
  padding: 20rpx;
  padding-bottom: 100rpx;
}

/* 筛选类型切换 */
.filter-tabs {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
  border-bottom: 1rpxolid #eee;
  padding-bottom: 20rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 8rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: #4a9eff;
  color: #fff;
  font-weight: 500;
}

/* 平台网格 */
.platform-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.platform-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s;
}

.platform-item.active {
  background: #4a9eff;
  box-shadow: 0 4rpx 16rpx rgba(74, 158, 255, 0.3);
}

.platform-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.platform-name {
  font-size: 24rpx;
  color: #666;
}

.platform-item.active .platform-name {
  color: #fff;
}

/* 类型网格 */
.genre-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.genre-item {
  padding: 20rpx 12rpx;
  background: #fff;
  border-radius: 8rpx;
  text-align: center;
  font-size: 24rpx;
  color: #666;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s;
}

.genre-item.active {
  background: #4a9eff;
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(74, 158, 255, 0.3);
}

/* 游戏列表 */
.game-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.game-card {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.3s;
}

.game-card:active {
  transform: scale(0.98);
}

.game-cover {
  width: 100%;
  height: 300rpx;
  background: #f0f0f0;
}

.game-info {
  padding: 16rpx;
}

.game-title {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.game-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
}

.game-rating {
  color: #ff9500;
}

.game-platform {
  color: #999;
}

/* 排行榜 */
.rank-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.3s;
}

.rank-item:active {
  transform: scale(0.98);
}

.rank-number {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #999;
  background: #f5f5f5;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.rank-number.top {
  background: linear-gradient(135deg, #ffd700, #ffed4e);
  color: #b8860b;
}

.rank-cover {
  width: 120rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.rank-info {
  flex: 1;
  overflow: hidden;
}

.rank-title {
  display: block;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rank-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
}

.rank-rating {
  color: #ff9500;
}

.rank-count {
  color: #999;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 100rpx 40rpx;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}


















































































































































































































